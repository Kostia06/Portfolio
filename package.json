{
	"name": "portfolio-cloudflare",
	"version": "0.1.0",
	"private": true,
	"overrides": {
		"cookie": "^0.7.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "npm run build && wrangler pages deploy .svelte-kit/cloudflare --project-name=portfolio",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/kit": "^2.49.3",
		"@sveltejs/vite-plugin-svelte": "^6.2.3",
		"@tailwindcss/vite": "^4.0.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"eslint": "^9.0.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.0.0",
		"puppeteer": "^24.36.1",
		"sharp": "^0.34.5",
		"svelte": "^5.46.1",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^7.3.1",
		"vite-plugin-pwa": "^1.2.0",
		"wrangler": "^4.0.0"
	},
	"dependencies": {
		"@google/genai": "^1.34.0",
		"gsap": "^3.14.2",
		"lenis": "^1.3.17",
		"motion": "^11.0.0",
		"splitting": "^1.1.0"
	},
	"type": "module"
}
